# ─── API Keys ──────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=social-listening-bot/1.0 by your_username
SERP_API_KEY=your_serpapi_key_here
OPENAI_API_KEY=your_openai_api_key_here   # optional, fallback to underthesea if empty
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Database ──────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=social_listening

POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=social_listening

# ─── Crawl Settings ────────────────────────────────────────────
# Comma-separated keywords to track
TRACK_KEYWORDS=VinFast,VF3,VF5,VF6,VF7,VF8,VF9,BYD,Atto 3,Dolphin,Seal,Xiaomi Auto,SU7,xe điện,EV Việt Nam

# How many YouTube videos/Reddit posts to fetch per run
YOUTUBE_MAX_RESULTS=50
REDDIT_MAX_POSTS=100
SERP_MAX_PAGES=3

# Sentiment threshold to trigger Telegram alert (negative score)
ALERT_NEGATIVE_THRESHOLD=0.75
